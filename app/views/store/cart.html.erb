<div class="content-card">
  <h1>Your Cart</h1>

  <% if @cart_items.empty? %>
    <p>Your cart is currently empty.</p>

    <div class="cart-actions">
      <%= link_to "Continue Shopping", root_path, class: "button-link secondary-button" %>
    </div>
  <% else %>
    <div class="cart-table-wrapper">
      <table class="cart-table">
        <thead>
          <tr>
            <th>Product</th>
            <th>Price</th>
            <th>Quantity</th>
            <th>Subtotal</th>
            <th>Actions</th>
          </tr>
        </thead>

        <tbody>
          <% @cart_items.each do |item| %>
            <tr>
              <td><%= item[:product].title %></td>

              <td>$<%= sprintf("%.2f", item[:product].price) %></td>

              <td>
                <%= form_with url: update_cart_path(item[:product]), method: :patch, local: true, html: { class: "cart-update-form" } do %>
                  <%= number_field_tag :quantity, item[:quantity], min: 1, class: "cart-quantity-input" %>
                  <%= button_tag "Update", type: "submit", class: "cart-update-btn" %>
                <% end %>
              </td>

              <td>$<%= sprintf("%.2f", item[:subtotal]) %></td>

              <td>
                <%= link_to "Remove",
                  remove_from_cart_path(item[:product]),
                  data: { turbo_method: :delete },
                  class: "button-link cart-remove-btn" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <div class="cart-summary">
      <h2>Total: $<%= sprintf("%.2f", @cart_total) %></h2>

      <div class="cart-actions">
        <%= link_to "Proceed to Checkout", checkout_path, class: "button-link primary-button" %>
        <%= link_to "Continue Shopping", root_path, class: "button-link secondary-button" %>
      </div>
    </div>
  <% end %>
</div>