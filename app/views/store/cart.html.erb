<h1>Your Cart</h1>

<% if @cart_items.empty? %>
  <p>Your cart is empty.</p>
<% else %>
  <table border="1" cellpadding="10">
    <thead>
      <tr>
        <th>Product</th>
        <th>Price</th>
        <th>Quantity</th>
        <th>Subtotal</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% @cart_items.each do |item| %>
        <tr>
          <td><%= item[:product].title %></td>
          <td>$<%= sprintf("%.2f", item[:product].price) %></td>
          <td>
            <%= form_with url: update_cart_path(item[:product]), method: :patch, local: true do %>
              <%= number_field_tag :quantity, item[:quantity], min: 1 %>
              <%= submit_tag "Update" %>
            <% end %>
          </td>
          <td>$<%= sprintf("%.2f", item[:subtotal]) %></td>
          <td>
            <%= button_to "Remove", remove_from_cart_path(item[:product]), method: :delete %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>

  <h2>Total: $<%= sprintf("%.2f", @cart_total) %></h2>
  <p><%= link_to "Proceed to Checkout", checkout_path %></p>
<% end %>

<p><%= link_to "Continue Shopping", root_path %></p>