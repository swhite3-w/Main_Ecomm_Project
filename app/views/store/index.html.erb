<h1>ArtForYou</h1>

<%= form_with url: root_path, method: :get, local: true do %>
  <div>
    <%= label_tag :keyword, "Search" %>
    <%= text_field_tag :keyword, params[:keyword] %>
  </div>

  <div>
    <%= label_tag :category_id, "Category" %>
    <%= select_tag :category_id,
        options_from_collection_for_select(@categories, :id, :name, params[:category_id]),
        include_blank: "All Categories" %>
  </div>

  <div>
    <%= label_tag :filter, "Filter" %>
    <%= select_tag :filter,
        options_for_select([["All", ""], ["Featured", "featured"], ["Active", "active"]], params[:filter]) %>
  </div>

  <%= submit_tag "Search" %>
<% end %>

<h2>Browse by Category</h2>
<ul>
  <% @categories.each do |category| %>
    <li><%= link_to category.name, category_path(category) %></li>
  <% end %>
</ul>

<h2>Products</h2>

<div class="products-grid">
  <% @products.each do |product| %>
    <div class="product-card">
      <% if product.image_url.present? %>
        <img src="<%= product.image_url %>" alt="<%= product.title %>" width="200">
      <% end %>

      <h3><%= link_to product.title, product_path(product) %></h3>
      <p><strong>Category:</strong> <%= product.category.name %></p>
      <p><%= truncate(product.description, length: 100) %></p>
      <p><strong>Price:</strong> $<%= sprintf("%.2f", product.price) %></p>
    </div>
  <% end %>
</div>

<div>
  <%= paginate @products %>
</div>