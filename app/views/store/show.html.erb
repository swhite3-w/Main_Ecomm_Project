<div class="content-card">
  <h1><%= @product.title %></h1>

  <div class="product-show">
    
    <!-- LEFT: IMAGE -->
    <div class="product-show-image">
      <%= image_tag "placeholder.jpg", class: "product-image-large" %>
    </div>

    <!-- RIGHT: DETAILS -->
    <div class="product-show-details">
      <p><strong>Category:</strong> <%= @product.category.name %></p>
      <p><strong>Price:</strong> $<%= sprintf("%.2f", @product.price) %></p>
      <p><strong>Stock:</strong> <%= @product.stock_quantity %></p>

      <p class="product-description">
        <%= @product.description.presence || "A curated piece from the ArtForYou collection." %>
      </p>

      <div class="product-show-actions">
        <%= button_to "Add to Cart",
            add_to_cart_path(@product),
            method: :post,
            class: "primary-button add-to-cart-btn",
            form_class: "add-to-cart-form" %>

        <%= link_to "Back to Home", root_path, class: "button-link secondary-button" %>
      </div>
    </div>

  </div>
</div>