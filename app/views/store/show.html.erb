<p>
  <%= link_to "Home", root_path %> >
  <%= link_to @product.category.name, category_path(@product.category) %> >
  <%= @product.title %>
</p>

<h1><%= @product.title %></h1>

<% if @product.image_url.present? %>
  <%= image_tag "placeholder.jpg", alt: "Artwork preview coming soon", class: "product-image" %>
<% end %>

<p><strong>Category:</strong> <%= @product.category.name %></p>
<p><strong>Price:</strong> $<%= sprintf("%.2f", @product.price) %></p>
<p><strong>Stock Quantity:</strong> <%= @product.stock_quantity %></p>
<p><strong>Featured:</strong> <%= @product.is_featured ? "Yes" : "No" %></p>
<p><strong>Active:</strong> <%= @product.is_active ? "Yes" : "No" %></p>

<p><%= @product.description %></p>

<p>
  <%= button_to "Add to Cart", add_to_cart_path(@product), method: :post %>
</p>

<p><%= link_to "Back to Home", root_path %></p>