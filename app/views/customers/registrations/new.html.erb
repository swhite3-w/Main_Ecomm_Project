<div class="content-card auth-card">
  <h1>Sign Up</h1>
  <p class="section-subtext">Create an account to save your details and complete checkout more easily.</p>

  <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "auth-form" }) do |f| %>
    <%= render "customers/shared/error_messages", resource: resource %>

    <div class="auth-grid auth-grid-signup">
      <div class="auth-field">
        <%= f.label :full_name, "Full Name" %>
        <%= f.text_field :full_name, autocomplete: "name" %>
      </div>

      <div class="auth-field">
        <%= f.label :email %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email" %>
      </div>

      <div class="auth-field">
        <%= f.label :province_id, "Province" %>
        <%= f.collection_select :province_id, Province.order(:name), :id, :name, { prompt: "Choose a province" }, {} %>
      </div>

      <div class="auth-field">
        <%= f.label :password %>
        <% if @minimum_password_length %>
          <p class="auth-help"><%= @minimum_password_length %> characters minimum</p>
        <% end %>
        <%= f.password_field :password, autocomplete: "new-password" %>
      </div>

      <div class="auth-field">
        <%= f.label :password_confirmation, "Password confirmation" %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password" %>
      </div>
    </div>

    <div class="auth-actions">
      <%= f.submit "Sign Up", class: "auth-submit" %>
    </div>
  <% end %>

  <div class="auth-links">
    <%= render "customers/shared/links" %>
  </div>
</div>