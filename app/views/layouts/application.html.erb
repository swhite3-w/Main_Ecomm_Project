<!DOCTYPE html>
<html>
  <head>
    <title>ArtForYou</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <header class="site-header">
      <div class="nav-container">
        <div class="site-brand">
          <h1 class="site-title">ArtForYou</h1>
          <p class="site-subtitle">Curated pieces with a refined shopping experience.</p>
        </div>

        <nav class="site-nav" aria-label="Main navigation">
          <%= link_to "Home", root_path, class: "nav-link" %>
          <%= link_to "About", about_path, class: "nav-link" %>
          <%= link_to "Contact", contact_path, class: "nav-link" %>
          <%= link_to "Cart", cart_path, class: "nav-link" %>

          <% if customer_signed_in? %>
            <%= link_to "Edit Account", edit_customer_registration_path, class: "nav-link" %>

            <%= button_to "Logout",
                destroy_customer_session_path,
                method: :delete,
                class: "nav-button",
                form: { class: "inline-logout-form" } %>
          <% else %>
            <%= link_to "Sign Up", new_customer_registration_path, class: "nav-link" %>
            <%= link_to "Login", new_customer_session_path, class: "nav-link" %>
          <% end %>

          <%= link_to "Admin", admin_root_path, class: "nav-link admin-link" %>
        </nav>
      </div>
    </header>

    <main class="page-container">
      <% flash.each do |type, message| %>
        <div class="flash-message <%= type == 'notice' ? 'flash-notice' : 'flash-alert' %>">
          <%= message %>
        </div>
      <% end %>

      <%= yield %>
    </main>
  </body>
</html>